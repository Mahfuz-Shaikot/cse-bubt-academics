%token NUMBER
%left '+' '-'
%left '*' '/'

%%
N : E { printf("\nValid Arithmetic Expression \nValue: %d\n", $1); }
  ;

E : E '+' E { $$ = $1 + $3; }
  | E '-' E { $$ = $1 - $3; }
  | E '*' E { $$ = $1 * $3; }
  | E '/' E { 
      if($3 == 0) { 
          fprintf(stderr, "Error: Division by zero\n"); 
          exit(1); 
      } 
      $$ = $1 / $3; 
    }
  | '(' E ')' { $$ = $2; }
  | NUMBER    { $$ = $1; }
  ;
%%